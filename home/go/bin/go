set -e

: ${PAGER:=/usr/bin/less -s}

go_cmd=$(/usr/bin/which go)
if [ "${go_cmd}" = "$0" ]; then
  cat <<eof >&2
cant' find Go installation

Found go command (/usr/bin/which -a go), first match wins:
$(/usr/bin/which -a go)
eof
  exit 1
fi

# page passes the output of go-command through PAGER.
page() {
  set -o pipefail
  eval "$@" | $PAGER
  exit $?
}

if [ -t 1 ]; then
  case "$1" in
    doc | help)
      page "${go_cmd}" "$@"
      ;;
    tool) # ex: go tool vet help
      if [ "$3" != "help" ]; then
        break
      fi
      page "${go_cmd}" "$@"
      ;;
  esac
fi

eval exec "${go_cmd}" "$@"
