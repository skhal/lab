[alias]
  x = log --all --decorate --oneline --graph
  today = !git x --since=midnight
  week = "!week() { dow=`date +%u`; since=`date -j -v-${dow}d +%Y-%m-%d` ; git x --since=$since; }; week"

[commit]
	gpgsign = true

[core]
  pager = less -x3,5

[include]
  path = ~/.gitconfig.local

[gpg]
	format = ssh
