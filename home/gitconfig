[alias "_x"]
  command = log --all --decorate --oneline --graph

[alias]
  x = !git '_x' --max-count=10
  today = !git '_x' --since=midnight
  week = "!week() { dow=`date +%u`; since=`date -j -v-${dow}d +%Y-%m-%d` ; git '_x' --since=$since; }; week"

[commit]
	gpgsign = true

[core]
  pager = less -x3,5

[include]
  path = ~/.gitconfig.local

[gpg]
	format = ssh
