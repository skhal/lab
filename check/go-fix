# go-fix is a pre-commit hook to run `go tool fix` on staged packages. It
# extracts packages from Go-files passed as arguments.
#
# SYNOPSIS
#
#   go-fix file [file ...]

set -e

packages=
for src; do
  pkg=$(dirname "$src")
  case "$packages" in
    *:$pkg:*)
      continue
      ;;
  esac
  packages="$packages:$pkg:"
done

IFS=:
for pkg in $packages; do
  if [ -z "$pkg" ]; then
    continue
  fi
  go fix ./"$pkg"/...
done
