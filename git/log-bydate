# log-bydate groups log messages by date. The log messages must have the
# following format:
#
#   * SHA DATE ...
#
# ENVIRONMENT
#
#   GITGROUP  disabled grouping if set to "no" or "false"
#
set -e

case "$GITGROUP" in
  [Nn][Oo] | [Ff][Aa][Ll][Ss][Ee])
    exec cut -d ' ' -f 1-2,4-
    ;;
esac

last_date=
while read star sha cur_date suffix; do
  if [ "${last_date}" != "${cur_date}" ]; then
    last_date="${cur_date}"
    echo "${cur_date}"
  fi
  echo "${star} ${sha} ${suffix}"
done
