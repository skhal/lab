# log-bydate groups log messages by date. The log messages must have the
# following format:
#
#   * DATE <suffix>
#
# for example:
#
#   * 2026-01-01 abc123 commit message
#
# ENVIRONMENT
#
#   GITGROUP  disabled grouping if set to "no" or "false"
#
set -e

case "$GITGROUP" in
  [Nn][Oo] | [Ff][Aa][Ll][Ss][Ee])
    exec cut -d ' ' -f 1,3-
    ;;
esac

last_date=
while read prefix date suffix; do
  if [ "${last_date}" != "${date}" ]; then
    last_date="${date}"
    echo "${date}"
  fi
  echo "${prefix} ${suffix}"
done
