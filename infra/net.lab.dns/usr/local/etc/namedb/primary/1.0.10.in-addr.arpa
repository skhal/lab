; file: /usr/local/etc/namedb/primary/lab.net-reverse.db
$TTL  1h
@       IN      SOA     lab.net. root.lab.net. (
                        2025100501 ; serial (yyyymmddnn)
                        1h         ; refresh
                        15m        ; update retry
                        1w         ; expiry
                        1d         ; minimum
)

; Name server
      IN  NS  dns.lab.net.

; Servers
11    IN  PTR ubuntu.lab.net.
