Host *.lab.net
  AddKeysToAgent yes
  ForwardAgent yes
  IdentityFile ~/.ssh/id_lab

Host nuc.lab.net
  User op 
  IdentityFile ~/.ssh/id_op_at_nuc

Host bastion
  AddKeysToAgent yes
  ForwardAgent yes
  HostName bastion.lab.net
  IdentityFile ~/.ssh/id_bastion

Host bsd.lab.net linux.lab.net alpine.lab.net ubuntu.lab.net
  ProxyJump jump@bastion
