$TTL  1h
@       IN      SOA     dns.lab.net. root.dns.lab.net. (
                        2026070701 ; serial (yyyymmddnn)
                        1h         ; refresh
                        15m        ; update retry
                        1w         ; expiry
                        1d         ; minimum
)

; Name server
       IN  NS  dns.lab.net.
       IN  A   10.0.0.2

; Servers
nuc     IN A 10.0.0.1
dns     IN A 10.0.0.2
